// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BiosProfile {
  id        String   @id
  bandName  String
  bandBio   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Track {
  id       String @id
  title    String
  artist   String
  album    String
  duration Int
  url      String
  coverUrl String?
  order    Int    @default(0)
}

model Photo {
  id           String @id
  title        String
  url          String
  thumbnailUrl String?
  description  String?
  order        Int    @default(0)
}

model Video {
  id           String @id
  title        String
  url          String
  thumbnailUrl String?
  duration     Int
  description  String?
  order        Int    @default(0)
}

model NewsArticle {
  id      String @id
  title   String
  content String
  date    String
  author  String?
  order   Int    @default(0)
}

model Wallpaper {
  id           String @id
  title        String
  url          String
  thumbnailUrl String?
  order        Int    @default(0)
}

model NoteDocument {
  id        String   @id
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}