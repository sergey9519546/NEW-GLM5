// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BiosProfile {
  id        String   @id
  bandName  String
  bandBio   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Track {
  id       String @id
  title    String
  artist   String
  album    String
  duration Int
  url      String
  coverUrl String?
  order    Int    @default(0)
}

model Photo {
  id           String @id
  title        String
  url          String
  thumbnailUrl String?
  description  String?
  order        Int    @default(0)
}

model Video {
  id           String @id
  title        String
  url          String
  thumbnailUrl String?
  duration     Int
  description  String?
  order        Int    @default(0)
}

model NewsArticle {
  id      String @id
  title   String
  content String
  date    String
  author  String?
  order   Int    @default(0)
}

model Wallpaper {
  id           String @id
  title        String
  url          String
  thumbnailUrl String?
  order        Int    @default(0)
}

model NoteDocument {
  id        String   @id
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id           String        @id
  createdAt    DateTime      @default(now())
  lastSeenAt   DateTime      @updatedAt
  vfsEntries   VfsEntry[]
  windowStates WindowState[]
  chatMessages ChatMessage[]
}

model VfsEntry {
  id        String    @id
  sessionId String
  parentId  String?
  name      String
  type      String
  content   String?
  mimeType  String?
  size      Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  session  Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parent   VfsEntry?  @relation("VfsEntryChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children VfsEntry[] @relation("VfsEntryChildren")

  @@index([sessionId, parentId])
  @@index([sessionId, updatedAt])
}

model WindowState {
  id          String   @id
  sessionId   String
  windowId    String
  title       String
  icon        String
  component   String
  propsJson   String?
  x           Int
  y           Int
  width       Int
  height      Int
  zIndex      Int
  isMinimized Boolean  @default(false)
  isMaximized Boolean  @default(false)
  preMaxX     Int?
  preMaxY     Int?
  preMaxW     Int?
  preMaxH     Int?
  updatedAt   DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, windowId])
  @@index([sessionId, updatedAt])
}

model Show {
  id          String   @id
  title       String
  venue       String
  date        DateTime
  description String?
  ticketUrl   String?
  posterUrl   String?
  status      String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatRoom {
  id          String        @id
  name        String
  description String?
  createdAt   DateTime      @default(now())
  messages    ChatMessage[]
}

model ChatMessage {
  id        String   @id
  roomId    String
  sessionId String
  username  String
  content   String
  type      String
  createdAt DateTime @default(now())

  room    ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  session Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([sessionId, createdAt])
}